    {
      "name": "start_interview",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseData = pm.response.json();\r",
              "\r",
              "switch (pm.response.code) {\r",
              "    case 200:\r",
              "        pm.collectionVariables.set(\"interview_id\", responseData.interview_id);\r",
              "        pm.test(\"Interview started successfully\");\r",
              "        break;\r",
              "\r",
              "    case 400:\r",
              "        pm.collectionVariables.set(\"interview_id\", responseData.detail.interview_id);\r",
              "        pm.test(\"Interview is already created\");\r",
              "        break;\r",
              "}\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
